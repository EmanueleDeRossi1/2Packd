<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#353535"
    android:padding="12dp"
    android:orientation="vertical">

    <!-- Top row: gym name + refresh button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/gym_name_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:text="Gym Name"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-light"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_toStartOf="@id/refresh_button"
            android:layout_marginEnd="12dp" />

        <ImageButton
            android:id="@+id/refresh_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="#A5A5A5"
            android:contentDescription="Refresh"
            android:scaleType="fitCenter"
            android:padding="4dp" />

    </RelativeLayout>

    <!-- Bottom row: percentage + chart, fills remaining height -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/current_occupancy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="35sp"
            android:fontFamily="sans-serif-light"
            android:textStyle="normal"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            android:layout_marginEnd="16dp" />

        <ImageView
            android:id="@+id/occupancy_chart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scaleType="fitXY"
            android:contentDescription="Occupancy chart throughout the day" />

    </LinearLayout>

</LinearLayout>